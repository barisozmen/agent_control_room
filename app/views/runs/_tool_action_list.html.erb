<%= turbo_frame_tag "tool_action_list" do %>
  <% tool_action_page = local_assigns.fetch(:tool_action_page) { run.tool_action_page } %>
  <% actions = tool_action_page.actions %>
  <% visible_count = actions.size %>
  <% total_count = tool_action_page.total_count %>
  <% latest_page = !tool_action_page.paginated? %>
  <% action_list_dom_id = latest_page ? "session_action_list" : "session_action_page_list" %>
  <% action_count_dom_id = latest_page ? "tool_action_count" : "tool_action_page_count" %>
  <% empty_state_dom_id = latest_page ? "session_action_empty_state" : "session_action_page_empty_state" %>

  <div class="flex min-h-[calc(100dvh-53px)] flex-col">
    <div class="ap-pane-header">
      <div class="flex flex-col gap-1 sm:flex-row sm:items-end sm:justify-between">
        <div>
          <p class="ap-kicker"><%= run.runtime_label.downcase %> session</p>
          <h2 id="tools-drawer-title" class="ap-pane-title mt-1">Action ledger</h2>
        </div>
        <p id="<%= action_count_dom_id %>" class="ap-mono text-xs ap-muted">
          <%= render "runs/tool_action_count", visible_count: visible_count, total_count: total_count %>
        </p>
      </div>
    </div>

    <div class="ap-scroll flex-1 overflow-auto">
      <ol id="<%= action_list_dom_id %>" data-testid="session-action-list" class="divide-y divide-[rgba(8,0,0,0.10)]">
        <%= render partial: "runs/tool_action", collection: actions, as: :action, locals: { run: run } %>
      </ol>

      <% unless actions.any? %>
        <div id="<%= empty_state_dom_id %>" class="p-4">
          <p class="ap-empty">no actions captured</p>
        </div>
      <% end %>

      <% if tool_action_page.more_actions? || tool_action_page.paginated? %>
        <div class="ap-pane-header flex items-center justify-between gap-3">
          <% if tool_action_page.more_actions? %>
            <%= link_to "Load older actions", run_tool_actions_path(run, before_id: tool_action_page.oldest_action_id), class: "ap-quiet-link", data: { turbo_frame: "tool_action_list" } %>
          <% end %>

          <% if tool_action_page.paginated? %>
            <%= link_to "Latest actions", run_tool_actions_path(run), class: "ap-quiet-link", data: { turbo_frame: "tool_action_list" } %>
          <% end %>
        </div>
      <% end %>
    </div>
  </div>
<% end %>
