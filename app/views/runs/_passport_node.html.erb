<li class="<%= depth.positive? ? "ap-tree-child" : "" %>">
  <% selected = selected_passport&.id == passport.id %>
  <% authority_summary = passport_authority_summary(passport) %>
  <% link_options = { class: "ap-passport-node #{selected ? "ap-passport-node-selected" : ""}", data: { turbo_frame: "_top" } } %>
  <% link_options[:aria] = { current: "page" } if selected %>
  <%= link_to run_path(run, passport_id: passport.id, panel: "passport"), link_options do %>
    <span class="ap-status-dot mt-2 shrink-0 <%= status_dot_classes(passport.status) %>" aria-hidden="true"></span>
    <span class="min-w-0 flex-1">
      <span class="flex min-w-0 items-start justify-between gap-3">
        <span class="block min-w-0 truncate text-sm font-semibold ap-text-strong"><%= passport.actor_name %></span>
        <% if selected && passport.children.any? %>
          <span class="ap-mono shrink-0 text-xs ap-muted"><%= pluralize(passport.children.size, "child") %></span>
        <% end %>
      </span>
      <span class="ap-status-text ap-mono mt-1 block truncate text-xs ap-muted">Status: <%= status_label(passport.status) %></span>
      <span class="ap-mono mt-1 block truncate text-xs <%= passport_authority_tone_classes(passport) %>" title="<%= passport_authority_detail(passport) %>"><%= authority_summary %></span>
    </span>
  <% end %>

  <% if passport.children.any? %>
    <ol class="ap-tree-line ml-4 mt-1 space-y-1 pl-4">
      <% passport.children.each do |child| %>
        <%= render "runs/passport_node", run: run, passport: child, selected_passport: selected_passport, depth: depth + 1 %>
      <% end %>
    </ol>
  <% end %>
</li>
