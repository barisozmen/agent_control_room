<main class="ap-shell min-h-dvh <%= "ap-shell-drawer-open" if @panel.present? %>" <% if @panel.present? %>data-controller="drawer" data-drawer-close-url-value="<%= run_path(@run, passport_id: @selected_passport&.id) %>"<% end %>>
  <%= turbo_stream_from @run %>

  <div data-drawer-target="background" <%= "inert" if @panel.present? %>>
    <%= render "runs/run_header", run: @run %>

    <section class="ap-workspace"
             data-controller="sidebar-resize"
             data-sidebar-resize-storage-key-value="agent-control-room:session-sidebar-width"
             data-sidebar-resize-min-value="176"
             data-sidebar-resize-max-value="420"
             data-sidebar-resize-reserved-width-value="740">
      <aside class="ap-panel ap-workspace-sidebar ap-workspace-sessions ap-border border-b lg:border-b-0 lg:border-r"
             data-sidebar-resize-target="sidebar panel"
             data-sidebar-resize-panel-name="session"
             data-sidebar-resize-width-variable="--ap-session-sidebar-width">
        <%= render partial: "runs/session_sidebar", locals: @session_sidebar || Run.session_sidebar_locals(selected_run: @run) %>
        <div class="ap-sidebar-resizer"
             role="separator"
             tabindex="0"
             aria-label="Resize sessions sidebar"
             aria-orientation="vertical"
             aria-controls="session_sidebar"
             aria-valuemin="176"
             aria-valuemax="420"
             aria-valuenow="208"
             title="Drag to resize sessions sidebar"
             data-sidebar-resize-target="handle"
             data-sidebar-resize-panel-name="session"
             data-sidebar-resize-reserved-width="420"
             data-sidebar-resize-reserved-panel-names="lineage"
             data-action="pointerdown->sidebar-resize#start keydown->sidebar-resize#handleKeydown"></div>
      </aside>

      <aside class="ap-panel ap-workspace-lineage ap-border border-b lg:border-b-0 lg:border-r"
             data-sidebar-resize-target="panel"
             data-sidebar-resize-panel-name="lineage"
             data-sidebar-resize-width-variable="--ap-lineage-width"
             data-sidebar-resize-storage-key="agent-control-room:runtime-lineage-width"
             data-sidebar-resize-min="260"
             data-sidebar-resize-max="560">
        <%= render "runs/passport_tree", run: @run, selected_passport: @selected_passport, passport_tree: @passport_tree %>
        <div class="ap-sidebar-resizer"
             role="separator"
             tabindex="0"
             aria-label="Resize runtime lineage"
             aria-orientation="vertical"
             aria-controls="passport_tree"
             aria-valuemin="260"
             aria-valuemax="560"
             aria-valuenow="320"
             title="Drag to resize runtime lineage"
             data-sidebar-resize-target="handle"
             data-sidebar-resize-panel-name="lineage"
             data-sidebar-resize-reserved-width="420"
             data-sidebar-resize-reserved-panel-names="session"
             data-action="pointerdown->sidebar-resize#start keydown->sidebar-resize#handleKeydown"></div>
      </aside>

      <section class="ap-panel ap-workspace-current-ask ap-focus-pane">
        <%= render "runs/permission_inbox", run: @run %>
      </section>
    </section>
  </div>

  <% if @panel.present? %>
    <aside class="ap-drawer ap-drawer-open" role="dialog" aria-modal="true" aria-labelledby="<%= @panel == "audit" ? "audit-drawer-title" : @panel == "tools" ? "tools-drawer-title" : "passport-drawer-title" %>" data-drawer-target="dialog" data-action="keydown@window->drawer#handleKeydown">
      <div class="ap-drawer-panel" tabindex="-1" data-drawer-target="panel">
        <div class="ap-drawer-topbar">
          <div class="flex items-center gap-2">
            <%= link_to "Passport", run_path(@run, passport_id: @selected_passport&.id, panel: "passport"), class: "ap-quiet-link #{@panel == "passport" ? "ap-quiet-link-active" : ""}" %>
            <%= link_to "Actions", run_path(@run, passport_id: @selected_passport&.id, panel: "tools"), class: "ap-quiet-link #{@panel == "tools" ? "ap-quiet-link-active" : ""}" %>
            <%= link_to "Receipts", run_path(@run, passport_id: @selected_passport&.id, panel: "audit"), class: "ap-quiet-link #{@panel == "audit" ? "ap-quiet-link-active" : ""}" %>
          </div>
          <%= link_to "Close", run_path(@run, passport_id: @selected_passport&.id), class: "ap-quiet-link" %>
        </div>

        <% if @panel == "audit" %>
          <%= render "runs/audit_timeline", run: @run, audit_event_page: @run.audit_timeline_page %>
        <% elsif @panel == "tools" %>
          <%= render "runs/tool_action_list", run: @run, tool_action_page: @tool_action_page || @run.tool_action_page %>
        <% else %>
          <%= render "runs/passport_detail", run: @run, passport: @selected_passport %>
        <% end %>
      </div>
    </aside>
  <% end %>
</main>
