<%= turbo_frame_tag "passport_detail" do %>
  <div class="flex h-full min-h-[360px] flex-col">
    <div class="ap-pane-header">
      <p class="ap-kicker">passport detail</p>
      <h2 id="passport-drawer-title" class="ap-pane-title mt-1"><%= passport&.actor_name || "No passport selected" %></h2>
    </div>

    <% if passport.present? %>
      <div class="ap-scroll flex-1 space-y-5 overflow-auto p-4">
        <section>
          <div class="flex items-center gap-2">
            <span class="ap-status-dot <%= status_dot_classes(passport.status) %>" aria-hidden="true"></span>
            <span class="ap-status-text ap-mono text-xs font-medium ap-body-muted">Status: <%= status_label(passport.status) %> / <%= passport.provider %> / <%= passport.actor_kind %></span>
          </div>
          <p class="ap-mono mt-3 break-words text-xs leading-5 ap-muted"><%= passport.lineage_label %></p>
          <% if passport.task.present? %>
            <p class="mt-3 text-sm leading-5 ap-body-muted"><%= passport.task %></p>
          <% end %>
        </section>

        <section>
          <div class="flex items-end justify-between gap-3">
            <h3 class="ap-kicker">effective authority</h3>
            <span class="ap-mono text-xs <%= passport_authority_tone_classes(passport) %>"><%= passport_authority_summary(passport) %></span>
          </div>
          <div class="ap-inspector-box mt-3 divide-y divide-[rgba(8,0,0,0.10)]">
            <% passport.capability_rows.each do |row| %>
              <div class="grid grid-cols-[88px_1fr] gap-3 px-3 py-2">
                <span class="ap-mono text-xs font-medium ap-text-strong"><%= row[:capability] %></span>
                <div class="min-w-0">
                  <div class="flex min-w-0 flex-wrap items-center gap-x-2 gap-y-1">
                    <span class="ap-mono text-xs font-medium <%= result_text_classes(row[:rule] == "allow" ? "allowed" : row[:rule] == "deny" ? "denied" : "ask") %>"><%= row[:rule] %></span>
                    <% if row[:parent_rule].present? && row[:parent_rule] != row[:rule] %>
                      <span class="ap-mono text-xs ap-muted">parent <%= row[:parent_rule] %></span>
                    <% end %>
                    <% if row[:grants].any? %>
                      <span class="ap-mono text-xs ap-result-positive"><%= pluralize(row[:grants].size, "grant") %></span>
                    <% end %>
                  </div>
                  <% if row[:grants].any? %>
                    <p class="ap-mono mt-1 truncate text-xs ap-muted"><%= row[:grants].map(&:pattern).join(" / ") %></p>
                  <% end %>
                </div>
              </div>
            <% end %>
          </div>
        </section>

        <section>
          <h3 class="ap-kicker">local grants</h3>
          <% if passport.grants.any? %>
            <div class="mt-3 space-y-2">
              <% passport.grants.order(:capability, :pattern).each do |grant| %>
                <div class="ap-inspector-box ap-subtle-panel px-3 py-2">
                  <div class="flex items-start justify-between gap-3">
                    <span class="ap-mono text-xs font-medium ap-text-strong"><%= grant.capability %></span>
                    <span class="ap-mono text-xs ap-result-positive"><%= grant.effect %></span>
                  </div>
                  <p class="ap-mono mt-1 break-words text-xs ap-body-muted"><%= grant.pattern %></p>
                </div>
              <% end %>
            </div>
          <% else %>
            <p class="ap-mono mt-2 text-xs ap-muted">no local grants</p>
          <% end %>
        </section>

        <section>
          <h3 class="ap-kicker">recent actions</h3>
          <% recent_actions = passport.tool_actions.order(requested_at: :desc, id: :desc).limit(3) %>
          <% if recent_actions.any? %>
            <div class="mt-3 space-y-2">
              <% recent_actions.each do |action| %>
                <%= link_to run_path(run, passport_id: passport.id, panel: "tools"), class: "ap-inspector-box block px-3 py-2", data: { turbo_frame: "_top" } do %>
                  <div class="flex items-start justify-between gap-3">
                    <p class="min-w-0 truncate text-sm font-medium ap-text-strong"><%= action.action_summary %></p>
                    <span class="ap-mono shrink-0 text-xs <%= result_text_classes(action.status) %>"><%= action.status %></span>
                  </div>
                  <p class="ap-mono mt-1 break-words text-xs ap-muted"><%= action.request_text %></p>
                <% end %>
              <% end %>
            </div>
          <% else %>
            <p class="ap-mono mt-2 text-xs ap-muted">no actions yet</p>
          <% end %>
        </section>
      </div>
    <% else %>
      <div class="p-4">
        <p class="ap-empty">select a passport</p>
      </div>
    <% end %>
  </div>
<% end %>
