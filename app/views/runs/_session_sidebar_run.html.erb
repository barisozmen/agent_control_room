<% selected = selected_run&.id == run.id %>
<% pending_count = pending_counts_by_run_id.fetch(run.id, 0) %>

<li data-session-filter-target="item" data-runtime-name="<%= run.runtime_name %>">
  <% link_options = { class: "ap-session-row #{selected ? "ap-session-row-selected" : ""}", data: { turbo_frame: "_top" } } %>
  <% link_options[:aria] = { current: "page" } if selected %>
  <%= link_to run_path(run), link_options do %>
    <span class="ap-status-dot mt-1 shrink-0 <%= status_dot_classes(run.status) %>" aria-hidden="true"></span>
    <span class="min-w-0 flex-1">
      <span class="block truncate text-sm font-semibold ap-text-strong"><%= session_sidebar_run_title(run) %></span>
      <span class="ap-status-text ap-mono mt-1 block truncate text-xs ap-muted">Status: <%= status_label(run.status) %></span>
      <span class="ap-mono mt-1 block truncate text-xs ap-body-muted">
        <%= session_sidebar_run_metadata(run) %>
      </span>
    </span>
    <% if pending_count.positive? %>
      <span class="ap-count-pill shrink-0"><%= pending_count %></span>
    <% end %>
  <% end %>
</li>
