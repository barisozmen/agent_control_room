<turbo-frame id="session_sidebar">
  <% pending_counts_by_run_id = local_assigns.fetch(:pending_counts_by_run_id) { {} } %>

  <div class="flex h-full flex-col">
    <div class="ap-pane-header">
      <div class="flex items-end justify-between gap-4">
        <div>
          <p class="ap-kicker">runtime sessions</p>
          <h2 class="ap-pane-title mt-1">Sessions</h2>
        </div>
        <span class="ap-mono text-xs ap-muted"><%= runs.size %></span>
      </div>
    </div>

    <div class="ap-scroll flex-1 overflow-auto p-2">
      <% if runs.any? %>
        <ol class="space-y-1">
          <% runs.each do |run| %>
            <% selected = selected_run&.id == run.id %>
            <% pending_count = pending_counts_by_run_id.fetch(run.id, 0) %>
            <li>
              <% link_options = { class: "ap-session-row #{selected ? "ap-session-row-selected" : ""}", data: { turbo_frame: "_top" } } %>
              <% link_options[:aria] = { current: "page" } if selected %>
              <%= link_to run_path(run), link_options do %>
                <span class="ap-status-dot mt-1 shrink-0 <%= status_dot_classes(run.status) %>" aria-hidden="true"></span>
                <span class="min-w-0 flex-1">
                  <span class="block truncate text-sm font-semibold ap-text-strong"><%= run.display_title %></span>
                  <span class="ap-status-text ap-mono mt-1 block truncate text-xs ap-muted">Status: <%= status_label(run.status) %></span>
                  <span class="ap-mono mt-1 block truncate text-xs ap-muted"><%= run.display_project %></span>
                  <span class="ap-mono mt-1 block truncate text-xs ap-body-muted">
                    <%= run.runtime_label %> / <%= run.runtime_session_id.presence || "demo-run-#{run.id}" %>
                  </span>
                </span>
                <% if pending_count.positive? %>
                  <span class="ap-count-pill shrink-0"><%= pending_count %></span>
                <% end %>
              <% end %>
            </li>
          <% end %>
        </ol>
      <% else %>
        <p class="ap-empty">no runtime sessions observed</p>
      <% end %>
    </div>
  </div>
</turbo-frame>
