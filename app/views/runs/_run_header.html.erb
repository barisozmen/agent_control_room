<%= turbo_frame_tag "run_header" do %>
  <% header_counts = run.header_counts %>
  <header class="ap-panel border-b px-4 py-3 sm:px-6">
    <div class="flex flex-col gap-3 lg:flex-row lg:items-center lg:justify-between">
      <div class="min-w-0">
        <div class="flex flex-wrap items-center gap-3">
          <div class="flex w-full min-w-0 items-center gap-2 sm:w-auto">
            <%= image_tag "/agent-control-room-logo.png", alt: "", width: 40, height: 40, class: "shrink-0" %>
            <h1 class="ap-mono min-w-0 text-2xl font-medium leading-tight ap-text-strong">Agent Identity Control Room</h1>
          </div>
          <span class="ap-mono inline-flex items-center gap-2 text-xs font-medium ap-body-muted">
            <span class="ap-status-dot <%= status_dot_classes(run.status) %>" aria-hidden="true"></span>
            <span class="ap-status-text">Status: <%= status_label(run.status) %></span>
          </span>
          <span class="ap-mono text-xs font-medium ap-body-muted"><%= pluralize(header_counts.passports, "passport") %></span>
          <span class="ap-mono text-xs font-medium ap-body-muted"><%= pluralize(header_counts.pending_permission_requests, "pending ask") %></span>
          <span class="ap-mono text-xs font-medium ap-body-muted"><%= pluralize(header_counts.tool_actions, "action") %></span>
        </div>
        <% if run.error_message.present? %>
          <p class="ap-mono mt-2 break-words text-xs ap-result-negative"><%= run.error_message %></p>
        <% end %>
        <% if run.failed? %>
          <p class="ap-mono mt-2 break-words text-xs ap-body-muted"><%= run.runtime_setup_guidance %></p>
        <% end %>
      </div>

      <div class="flex flex-wrap items-center gap-3">
        <%= link_to "Actions", run_path(run, panel: "tools"), class: "ap-quiet-link", data: { turbo_frame: "_top" } %>
        <%= link_to "Receipts", run_path(run, panel: "audit"), class: "ap-quiet-link", data: { turbo_frame: "_top" } %>
        <% if run.active? %>
          <span class="ap-mono text-xs ap-muted">run in progress</span>
        <% else %>
          <%= button_to run.failed? ? "Retry #{run.runtime_label} demo" : "New #{run.runtime_label} demo", runs_path, params: { runtime_name: run.runtime_name }, method: :post, class: command_button_classes(:secondary), form: { data: { turbo_frame: "_top" } } %>
        <% end %>
      </div>
    </div>
  </header>
<% end %>
