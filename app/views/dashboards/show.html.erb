<main class="ap-shell min-h-dvh">
  <div class="ap-border border-b px-4 py-3 sm:px-6">
    <div class="flex flex-col gap-3 sm:flex-row sm:items-center sm:justify-between">
      <div>
        <p class="ap-kicker">local runtime control</p>
        <div class="flex min-w-0 items-center gap-2">
          <%= image_tag "/agent-control-room-logo.png", alt: "", width: 40, height: 40, class: "shrink-0" %>
          <h1 class="ap-mono min-w-0 text-2xl font-medium leading-tight ap-text-strong">Agent Identity Control Room</h1>
        </div>
      </div>

      <div class="flex flex-wrap items-center gap-2">
        <% RuntimeAdapters::Registry.options.each_with_index do |runtime, index| %>
          <%= button_to "#{runtime.label} demo", runs_path, params: { runtime_name: runtime.name }, method: :post, class: command_button_classes(index.zero? ? :primary : :secondary) %>
        <% end %>
      </div>
    </div>
  </div>

  <section class="ap-workspace ap-workspace-empty"
           data-controller="sidebar-resize"
           data-sidebar-resize-storage-key-value="agent-control-room:session-sidebar-width"
           data-sidebar-resize-min-value="176"
           data-sidebar-resize-max-value="420"
           data-sidebar-resize-reserved-width-value="360">
    <aside class="ap-panel ap-workspace-sidebar ap-border border-b lg:border-b-0 lg:border-r" data-sidebar-resize-target="sidebar">
      <%= render partial: "runs/session_sidebar", locals: @session_sidebar || Run.session_sidebar_locals(selected_run: nil) %>
      <div class="ap-sidebar-resizer"
           role="separator"
           tabindex="0"
           aria-label="Resize sessions sidebar"
           aria-orientation="vertical"
           aria-controls="session_sidebar"
           aria-valuemin="176"
           aria-valuemax="420"
           aria-valuenow="208"
           title="Drag to resize sessions sidebar"
           data-sidebar-resize-target="handle"
           data-action="pointerdown->sidebar-resize#start keydown->sidebar-resize#handleKeydown"></div>
    </aside>

    <div class="grid min-h-[calc(100dvh-73px)] place-items-center px-4 lg:col-span-2">
      <div class="ap-inspector-box ap-subtle-panel w-full max-w-[720px] p-6" data-testid="empty-start-panel">
        <p class="ap-kicker">no sessions yet</p>
        <h2 class="mt-2 text-3xl font-medium leading-tight ap-text-strong">Runtime observer is waiting</h2>
        <p class="ap-mono mt-3 text-sm ap-body-muted">start an observed runtime session on this computer, or run a scripted demo</p>
        <div class="mt-5 flex flex-wrap gap-2">
          <% RuntimeAdapters::Registry.options.each_with_index do |runtime, index| %>
            <%= button_to "#{runtime.label} demo", runs_path, params: { runtime_name: runtime.name }, method: :post, class: command_button_classes(index.zero? ? :primary : :secondary) %>
          <% end %>
        </div>
      </div>
    </div>
  </section>
</main>
